{
  "name": "Paperclip AI",
  "version": "2.1.2",
  "slug": "paperclip",
  "description": "Multi-Agent Orchestration Platform for AI Agents",
  "url": "https://github.com/SvenSowa/paperclip-ha-addon",
  "arch": ["aarch64", "amd64"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 3100,
  "panel_icon": "mdi:robot-outline",
  "ports": {
    "3100/tcp": 3100
  },
  "ports_description": {
    "3100/tcp": "Paperclip Web UI & API (optional direct access)"
  },
  "options": {
    "log_level": "info",
    "database": {
      "type": "embedded"
    },
    "deployment": {
      "exposure": "private"
    },
    "backup": {
      "enabled": true,
      "retention_days": 30,
      "interval_minutes": 60,
      "path": ""
    },
    "public_url": "",
    "allowed_hostnames": [],
    "disable_telemetry": true,
    "azure_foundry": {
      "enabled": false,
      "endpoint": "",
      "api_key": ""
    }
  },
  "schema": {
    "log_level": "list(trace|debug|info|warning|error)",
    "database": {
      "type": "list(embedded|postgres)",
      "postgres_host": "str?",
      "postgres_port": "port?",
      "postgres_user": "str?",
      "postgres_password": "password?",
      "postgres_database": "str?"
    },
    "deployment": {
      "exposure": "list(private|public)"
    },
    "backup": {
      "enabled": "bool",
      "retention_days": "int",
      "interval_minutes": "int",
      "path": "str?"
    },
    "public_url": "str?",
    "allowed_hostnames": ["str"],
    "disable_telemetry": "bool",
    "azure_foundry": {
      "enabled": "bool",
      "endpoint": "str?",
      "api_key": "password?"
    }
  }
}