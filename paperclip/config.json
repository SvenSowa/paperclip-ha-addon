{
  "name": "Paperclip AI",
  "version": "2.0.0",
  "slug": "paperclip",
  "description": "Multi-Agent Orchestration Platform for AI Agents",
  "url": "https://github.com/SvenSowa/paperclip-ha-addon",
  "arch": ["aarch64", "amd64"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 3100,
  "panel_icon": "mdi:robot-outline",
  "ports": {
    "3100/tcp": null
  },
  "ports_description": {
    "3100/tcp": "Paperclip Web UI & API (optional direct access)"
  },
  "options": {
    "log_level": "info",
    "database": {
      "type": "embedded"
    },
    "public_url": "",
    "disable_telemetry": true
  },
  "schema": {
    "log_level": "list(trace|debug|info|warning|error)",
    "database": {
      "type": "list(embedded|postgres)",
      "postgres_host": "str?",
      "postgres_port": "port?",
      "postgres_user": "str?",
      "postgres_password": "password?",
      "postgres_database": "str?"
    },
    "public_url": "str?",
    "disable_telemetry": "bool"
  }
}